# Tankerkoenig API key — register at https://creativecommons.tankerkoenig.de/
FUEL_MCP_TANKERKOENIG_API_KEY=your-api-key-here

# Log level (DEBUG, INFO, WARNING, ERROR)
FUEL_MCP_LOG_LEVEL=INFO

# Default search radius in km
FUEL_MCP_DEFAULT_RADIUS_KM=15

# Demo mode (set to true to use mock data without API key)
# FUEL_MCP_DEMO_MODE=true
# FUEL_MCP_DEMO_SCENARIO=default
